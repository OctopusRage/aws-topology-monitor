# Server
PORT=4000

# Data source: false = mock topology, true = live AWS (needs credentials)
USE_AWS=false
AWS_REGION=ap-southeast-1
# When USE_AWS=true, provide credentials via the standard AWS chain:
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN, or an instance role.

# Metrics: Prometheus that scrapes node_exporter
PROMETHEUS_URL=http://localhost:9090
NODE_EXPORTER_PORT=9100
ROOT_MOUNT=/

# true = synthesize metric series (demo), false = query Prometheus for real
MOCK_METRICS=true

# Request Count source: pull ALB's native RequestCount from CloudWatch
# (per target group) instead of the node_exporter network proxy.
# Needs AWS credentials + real ARNs. CPU/RAM/Storage still come from Prometheus.
USE_CLOUDWATCH_REQUESTS=false

# Auth / users (SQLite via node:sqlite — no native deps)
DB_PATH=./data.db
# Default admin seeded on first run only (when the users table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
