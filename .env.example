# ── docker-compose deploy config ──
# Host port the web UI is served on
WEB_PORT=8080

# Data source
USE_AWS=true
AWS_REGION=ap-southeast-3
# Provide credentials here, OR mount ~/.aws in docker-compose.yml (see comment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Metrics
MOCK_METRICS=true
PROMETHEUS_URL=http://prometheus:9090
NODE_EXPORTER_PORT=9100
USE_CLOUDWATCH_REQUESTS=true

# Default admin seeded on first run (change before deploy!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
